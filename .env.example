# ── Maintainerr (source of the deletion schedule) ───────────────────────────
# Maintainerr has NO authentication — point this at an INTERNAL address only and
# never expose Maintainerr to the internet.
MAINTAINERR_URL=http://maintainerr:6246
# Only watch these collection titles (comma-separated). Leave blank to watch
# every collection that has a "Media deleted after days" set.
COLLECTION_ALLOWLIST=

# ── Jellyseerr (requester + email lookup) ───────────────────────────────────
JELLYSEERR_URL=http://jellyseerr:5055
JELLYSEERR_API_KEY=

# ── Jellystat (recent-watcher lookup) ───────────────────────────────────────
JELLYSTAT_URL=http://jellystat:3000
JELLYSTAT_TOKEN=
# A watch within this many days counts as "recent".
WATCHER_LOOKBACK_DAYS=90

# ── Who gets emailed ────────────────────────────────────────────────────────
NOTIFY_REQUESTER=true
NOTIFY_WATCHERS=true
ADMIN_EMAIL=

# ── Timing ──────────────────────────────────────────────────────────────────
# 0 = email immediately when a title is marked, announcing the full countdown
# ("deletes on <date>, in N days"). Set > 0 to instead wait until the deletion
# is within that many days.
NOTIFY_DAYS_BEFORE=0
# Also send a "was removed" confirmation once it actually leaves.
NOTIFY_ON_REMOVAL=false
# Batching: at most ONE email per person per day, listing all their pending
# titles. Held until DIGEST_HOUR:DIGEST_MINUTE (local time / TZ), then sent on
# the next poll.
DIGEST_HOUR=9
DIGEST_MINUTE=0

# ── Email (SMTP) ────────────────────────────────────────────────────────────
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_SECURITY=starttls          # starttls (587) | ssl (465) | none
SMTP_USER=
SMTP_PASSWORD=                  # iCloud/Gmail: app-specific password
EMAIL_FROM=                     # defaults to SMTP_USER
SENDER_NAME=Bastien's Jellyfin

# ── Email copy ──────────────────────────────────────────────────────────────
SERVER_NAME=the Jellyfin server
KEEP_INSTRUCTIONS=reply to this email before then and I'll keep it.

# ── Web app: dashboard + self-service keep endpoint ─────────────────────────
WEB_ENABLED=true
WEB_HOST=0.0.0.0
WEB_PORT=8623
# Public tunnel hostname the "Keep this" email button points at. Leave blank to
# omit keep links from emails (falls back to KEEP_INSTRUCTIONS text).
PUBLIC_BASE_URL=https://sendoff.example.com
# HMAC secret for signing keep tokens. Generate once:
#   python -c "import secrets; print(secrets.token_urlsafe(32))"
SIGNING_SECRET=

# ── Dashboard auth (the /keep route is NEVER behind this) ────────────────────
# HTTP Basic Auth for the read-only dashboard. Fail-closed: if neither Basic
# Auth nor TRUST_PROXY_AUTH is set, the dashboard refuses to serve.
DASHBOARD_USER=admin
DASHBOARD_PASSWORD=
# Set true ONLY if Cloudflare Access / an authenticated proxy already gates the
# dashboard and sendoff isn't reachable directly. Then Basic Auth is skipped.
TRUST_PROXY_AUTH=false

# ── Behaviour ───────────────────────────────────────────────────────────────
# Log exactly who WOULD be emailed but send nothing. Start true; flip to false
# once the recipient resolution looks right.
DRY_RUN=true
POLL_INTERVAL=3600
DB_PATH=/data/sendoff.db
TZ=Europe/Amsterdam
LOG_LEVEL=INFO
